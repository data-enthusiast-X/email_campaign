generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id                String          @id @default(cuid())
  name              String
  plan              String          @default("free")
  emailsSentMonth   Int             @default(0)
  emailsLimit       Int             @default(5000)
  verifUsedMonth    Int             @default(0)
  verifLimit        Int             @default(500)
  createdAt         DateTime        @default(now())
  brandName         String?
  brandColour       String?         @default("#E8561A")
  brandLogo         String?
  brandWebsite      String?
  users             User[]
  contacts          Contact[]
  campaigns         Campaign[]
  sendingDomains    SendingDomain[]
  tags              Tag[]
  activityLogs      ActivityLog[]
  importLogs        ImportLog[]
}

model User {
  id            String    @id @default(cuid())
  workspaceId   String
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model Contact {
  id                    String    @id @default(cuid())
  workspaceId           String
  email                 String
  firstName             String?
  lastName              String?
  phone                 String?
  company               String?
  jobTitle              String?
  subscriptionStatus    String    @default("subscribed")
  verificationStatus    String    @default("unverified")
  verificationCheckedAt DateTime?
  engagementScore       Int       @default(0)
  lifecycleStage        String    @default("lead")
  source                String?
  country               String?
  city                  String?
  region                String?
  timezone              String?
  language              String?
  lastSeenAt            DateTime?
  lastSeenDevice        String?
  lastSeenClient        String?
  lastSeenIp            String?
  createdAt             DateTime  @default(now())
  deletedAt             DateTime?
  deletedBy             String?
  unsubscribeReason     String?
  subscriptionUpdatedAt DateTime?
  workspace             Workspace @relation(fields: [workspaceId], references: [id])
  tags                  ContactTag[]

  @@unique([workspaceId, email])
  @@index([workspaceId, verificationStatus])
  @@index([workspaceId, subscriptionStatus])
}

model Campaign {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  subject        String?
  previewText    String?
  fromName       String?
  fromEmail      String?
  htmlContent    String?
  status         String    @default("draft")
  recipientCount Int       @default(0)
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
}

model SendingDomain {
  id               String    @id @default(cuid())
  workspaceId      String
  domain           String
  spfVerified      Boolean   @default(false)
  dkim1Verified    Boolean   @default(false)
  dkim2Verified    Boolean   @default(false)
  dmarcVerified    Boolean   @default(false)
  warmupActive     Boolean   @default(false)
  warmupDay        Int       @default(0)
  warmupDailyLimit Int       @default(20)
  healthScore      Int       @default(0)
  createdAt        DateTime  @default(now())
  workspace        Workspace @relation(fields: [workspaceId], references: [id])
}

model Tag {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  colour      String       @default("#E8561A")
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  contacts    ContactTag[]

  @@unique([workspaceId, name])
}

model ContactTag {
  contactId String
  tagId     String
  addedAt   DateTime @default(now())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model ActivityLog {
  id          String    @id @default(cuid())
  workspaceId String
  contactId   String?
  userId      String?
  userEmail   String?
  action      String
  details     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model ImportLog {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String?
  userEmail   String?
  fileName    String
  added       Int       @default(0)
  skipped     Int       @default(0)
  totalRows   Int       @default(0)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}
